#include <Wire.h>
#include "MAX30105.h"
#include "heartRate.h"
#include <Adafruit_GFX.h>
#include <Adafruit_SSD1306.h>

MAX30105 particleSensor;

#define SCREEN_WIDTH  128
#define SCREEN_HEIGHT  64
Adafruit_SSD1306 display(SCREEN_WIDTH, SCREEN_HEIGHT, &Wire, -1); 

const byte RATE_SIZE = 10; // smaller but more stable
byte rates[RATE_SIZE];
byte rateSpot = 0;
int validBeatCount=0;

// Improved filtering
float filteredBPM =0;
const float ALPHA = 0.3; // Low-pass filter coefficient (0.1-0.5)

// Beat validation
const float MIN_BPM = 50;
const float MAX_BPM = 200;
const long MIN_BEAT_INTERVAL = 300;  // 300ms min (200 BPM max)
const long MAX_BEAT_INTERVAL = 1500; // 1.5s max (40 BPM min)

long lastBeat = 0;
float beatsPerMinute = 0;
int beatAvg = 0;

// display timing control
unsigned long lastDisplayUpdate = 0;
const int displayInterval = 500; // ms

void setup()
{
  Serial.begin(115200);
  Serial.println("HR Monitor Starting...");

  // Set stable I2C speed
  Wire.begin();
  Wire.setClock(200000); // 200kHz (important)

  // Initialize display
  if(!display.begin(SSD1306_SWITCHCAPVCC, 0x3C)) {
    Serial.println("Display failed");
    for(;;);
  }

  if(!particleSensor.begin(Wire)) {
    Serial.println("Sensor not found");
    for(;;);
  }

  particleSensor.setup();
  particleSensor.setPulseAmplitudeRed(0x0A);
}

void loop()
{
  long irValue = particleSensor.getIR();

 // FINGER BEAT DETECTION- only process if finger is present
if (irValue > 50000) {
  // Heartbeat detection
  if (checkForBeat(irValue)) {
    long delta = millis() - lastBeat;

    //BEAT VALIDATION
    if (delta > MIN_BEAT_INTERVAL && delta < MAX_BEAT_INTERVAL)
      {
    beatsPerMinute = 60.0 / (delta / 1000.0);

      if (beatsPerMinute > MIN_BPM && beatsPerMinute < MAX_BPM);
    // Store in Array
    {
      rates[rateSpot++] = (byte)beatsPerMinute;
      rateSpot %= RATE_SIZE;
      validBeatCount++;
      // Counts valid beats only
   
    // The moving average values
    beatAvg=0;
    for (byte x =0; x < RATE_SIZE; x++)
      beatAvg += rates[x];  
    beatAvg /= RATE_SIZE;

    // LOW-PASS FILTER 
    filteredBPM = ALPHA * beatsPerMinute + (1-ALPHA) * filteredBPM;
    }
      }
      lastBeat=millis();
  }
} else { 
  validBeatCount=0; 
}
// Display
if (millis() - lastDisplayUpdate > displayInterval) { 
  lastDisplayUpdate = millis();

  display.clearDisplay();
  display.setTextSize (2);
  display.setTextColor (WHITE);
  display.setCursor(0,0);

  display.print("BPM: ");
  display.println((int)filteredBPM); 
  
  display.setTextSize(1);
  display.print("Avg: "); display.print(beatAvg);
  display.print(" ("); display.print(validBeatCount); display.println(")");
    
  if (irValue < 50000) {
      display.println("No finger?");
    }
    
  display.display();
  }
}
